<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/page_bg">

    <!-- Top toolbar -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingHorizontal="12dp" android:paddingTop="48dp" android:paddingBottom="8dp">
        <com.google.android.material.button.MaterialButton android:id="@+id/btnBackGuide"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/nav_back" android:textColor="@color/cyan"
            app:icon="@drawable/ic_arrow_back" app:iconTint="@color/cyan"/>
        <TextView android:id="@+id/tvGuideSection"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:textSize="12sp" android:textStyle="bold"
            android:letterSpacing="0.1" android:gravity="center"/>
        <TextView android:id="@+id/tvGuideStepNum"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="12sp" android:textColor="@color/hint_color"
            android:paddingHorizontal="12dp"/>
    </LinearLayout>

    <!-- Content (scrollable) -->
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:paddingHorizontal="20dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:paddingVertical="16dp">

            <!-- Step title -->
            <TextView android:id="@+id/tvGuideTitle"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="24sp" android:textStyle="bold"
                android:textColor="?colorOnBackground" android:layout_marginBottom="14dp"
                android:lineSpacingMultiplier="1.2"/>

            <!-- Body card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_bg" app:cardCornerRadius="16dp"
                app:cardElevation="0dp" android:layout_marginBottom="14dp">
                <TextView android:id="@+id/tvGuideBody"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textSize="14sp" android:textColor="?colorOnSurface"
                    android:lineSpacingMultiplier="1.6" android:padding="18dp"/>
            </com.google.android.material.card.MaterialCardView>

            <!-- Tip card -->
            <com.google.android.material.card.MaterialCardView android:id="@+id/cardGuideTip"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardBackgroundColor="#1400C8FF" app:cardCornerRadius="16dp"
                app:cardElevation="0dp" app:strokeColor="#3300C8FF" app:strokeWidth="1dp"
                android:layout_marginBottom="8dp" android:visibility="gone">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="&#128161;" android:textSize="18sp" android:layout_marginEnd="10dp"/>
                    <TextView android:id="@+id/tvGuideTip"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textSize="13sp"
                        android:textColor="@color/cyan" android:lineSpacingMultiplier="1.4"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>

    <!-- Bottom nav -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:background="@color/page_bg"
        android:paddingHorizontal="20dp" android:paddingTop="12dp" android:paddingBottom="28dp">

        <!-- Dot indicators -->
        <LinearLayout android:id="@+id/guideDots"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_gravity="center_horizontal"
            android:layout_marginBottom="14dp"/>

        <!-- Prev / Next -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">
            <com.google.android.material.button.MaterialButton android:id="@+id/btnGuidePrev"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1"
                android:text="@string/guide_prev" app:strokeColor="@color/hint_color"
                android:textColor="@color/hint_color" app:cornerRadius="14dp"
                android:layout_marginEnd="10dp" android:enabled="false"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/btnGuideNext"
                android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1"
                android:text="@string/guide_next" app:backgroundTint="@color/cyan"
                android:textColor="#0A0F1E" android:textStyle="bold" app:cornerRadius="14dp"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
